{
  "manifest_version": 3,
  "name": "promptPACK",
  "version": "1.0.0",
  "description": "Local-first Chrome extension for objective-aware prompt compression, preservation controls, and human-in-the-loop prompt handoff.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [],
  "action": {
    "default_title": "Open promptPACK"
  },
  "background": {
    "service_worker": "src/service_worker.js"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}